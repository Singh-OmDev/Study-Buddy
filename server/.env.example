# Sign up at https://www.scraperapi.com — leave blank for local dev (direct requests work locally)
SCRAPER_API_KEY=
# Updated Standard Multi-Host Format (more reliable than mongodb+srv)
MONGO_URI=mongodb://<username>:<password>@ac-hherxok-shard-00-00.w4jxko7.mongodb.net:27017,ac-hherxok-shard-00-01.w4jxko7.mongodb.net:27017,ac-hherxok-shard-00-02.w4jxko7.mongodb.net:27017/?replicaSet=atlas-5rwluj-shard-0&authSource=admin&retryWrites=true&w=majority&tls=true

GROQ_API_KEY=your_groq_api_key
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key

